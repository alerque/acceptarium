root = true

[*]
end_of_line = lf
insert_final_newline = true
charset = utf-8
trim_trailing_whitespace = true

[{Makefile*,*.mk,*.mk.in}]
indent_style = tab
indent_size = 4

[*.m4]
indent_style = space
indent_size = 8

[*.md]
trim_trailing_whitespace = false

[{*.py,*.py.in}]
indent_style = space
indent_size = 4

[*.rs]
indent_style = space
indent_size = 4

[{*.sh,*.sh.in}]
indent_style = tab
indent_size = 4
