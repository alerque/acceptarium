alias acceptarium="${ACCEPTARIUM:-acceptarium}"
alias env="${ENV:-@ENV@}"
alias grep="${GREP:-@GREP@}"

function flunk () {
	echo "Error: $@" >2
	exit 1
}

function debug_env () {
	env | grep '^ACCEPTARIUM'
}
